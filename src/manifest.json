{
  "manifest_version": 3,
  "name": "Your Rapport",
  "description": "An open source chrome extension for grabbing screenshots from the internet and making them searchable and downloadable.",
  "options_page": "options.html",
  "background": { "service_worker": "background.bundle.js" },
  "action": {
    "default_icon": "icon-48.png",
    "default_title": "Your Rapport is a screenshot tool. Right click, select Collect or Ctrl+Shift+S to save. Ctrl+Shift+X open the dashboard."
  },
  "version": "0.1.4",
  "icons": {
    "128": "icon-128.png",
    "48": "icon-48.png",
    "16": "icon-16.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icon-128.png", "icon-48.png"],
      "matches": []
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.bundle.js"]
    }
  ],
  "permissions": ["unlimitedStorage", "storage", "contextMenus", "activeTab"],
  "commands": {
    "singleCapture": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      },
      "description": "Save the current page"
    },
    "openDashboard": {
      "suggested_key": {
        "default": "Ctrl+Shift+X"
      },
      "description": "Open Dashboard"
    },
    "startCapture": {
      "suggested_key": {
        "default": "Ctrl+Shift+Z"
      },
      "description": "Starts and stops auto scroll"
    }
  }
}
