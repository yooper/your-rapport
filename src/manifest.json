{
  "manifest_version": 3,
  "name": "Your Rapport",
  "description": "An open source chrome extension for grabbing screenshots from the internet and making them searchable and downloadable.",
  "options_page": "options.html",
  "background": { "service_worker": "background.bundle.js" },
  "action": {
    "default_icon": "icon-48.png",
    "default_title": "Your Rapport is a screenshot tool with auto scroll capabilities. Right click, select Collect or Ctrl+Shift+S to save. Ctrl+Shift+Z for auto scrolling captures. Ctrl+Shift+X open the dashboard.",
    "default_popup": "popup.html"
  },
  "version": "0.10.0",
  "icons": {
    "128": "icon-128.png",
    "48": "icon-48.png",
    "16": "icon-16.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content.styles.css", "icon-128.png", "icon-48.png"],
      "matches": []
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.bundle.js"],
      "css": ["content.styles.css"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["<all_urls>"],
  "permissions": [
    "unlimitedStorage",
    "storage",
    "contextMenus",
    "activeTab",
    "tabs",
    "webNavigation"
  ],
  "commands": {
    "initStartCapture": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      },
      "description": "Save a single web page page screenshot"
    },
    "initAutoScroll": {
      "suggested_key": {
        "default": "Ctrl+Shift+Z"
      },
      "description": "Starts and stops auto scroll collection process."
    },
    "initScanPage": {
      "suggested_key": {
        "default": "Ctrl+Shift+F"
      },
      "description": "Scan the current web page for known selectors."
    },
    "reload": {
      "suggested_key": {
        "default": "Ctrl+Shift+D"
      },
      "description": "Reloads the runtime."
    }
  },
  "externally_connectable": {
    "ids": ["gdnhlhadhgnhaenfcphpeakdghkccfoo"]
  },
  "key": ""
}
